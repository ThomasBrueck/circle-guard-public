pipeline {
    agent any
    environment {
        SERVICE_NAME = "circleguard-identity-service"
        IMAGE_NAME   = "circle-guard/circleguard-identity-service"
        IMAGE_TAG    = "${env.BUILD_NUMBER}"
        K8S_NS       = "dev"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \
                        -f services/${SERVICE_NAME}/Dockerfile \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        .
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    minikube image load ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }
        stage('Unit Tests') {
            steps {
                sh """
                    docker build --target builder \
                        -f services/${SERVICE_NAME}/Dockerfile \
                        -t ${IMAGE_NAME}:builder-${IMAGE_TAG} \
                        .
                    docker run --name test-runner-${IMAGE_TAG} \
                        ${IMAGE_NAME}:builder-${IMAGE_TAG} \
                        ./gradlew :services:${SERVICE_NAME}:test; TEST_EXIT=\$?
                    mkdir -p test-results
                    docker cp test-runner-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results test-results/ || true
                    docker rm test-runner-${IMAGE_TAG} || true
                    exit \$TEST_EXIT
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results/**/*.xml'
                }
            }
        }
        stage('Deploy to Dev K8s') {
            steps {
                sh "kubectl create namespace ${K8S_NS} --dry-run=client -o yaml | kubectl apply -f -"
                sh "kubectl apply -f k8s/dev/${SERVICE_NAME}-deployment.yaml -n ${K8S_NS}"
                sh "kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${IMAGE_NAME}:${IMAGE_TAG} -n ${K8S_NS}"
                sh "kubectl rollout status deployment/${SERVICE_NAME} -n ${K8S_NS} --timeout=120s"
            }
        }
    }
    post {
        failure { echo "Pipeline FALLÓ para ${SERVICE_NAME}" }
        success { echo "Pipeline DEV completado para ${SERVICE_NAME}:${IMAGE_TAG}" }
    }
}
